<Window x:Class="TaskbarMusic.CatWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="cat"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        ShowActivated="False"
        IsHitTestVisible="False"
        WindowStartupLocation="Manual"
        Left="-6000" Top="-6000"
        Width="150" Height="96"
        UseLayoutRounding="True">

    <!-- Everything slides horizontally as one unit. -->
    <Canvas x:Name="Root" Width="150" Height="96">
        <Canvas.RenderTransform>
            <TranslateTransform x:Name="Slide" X="-150"/>
        </Canvas.RenderTransform>

        <!-- Quiet grounding shadow. -->
        <Ellipse Canvas.Left="55" Canvas.Top="84" Width="78" Height="6" Fill="#30000000"/>

        <!--
            Abstract cat mark: clean organic geometry and a restrained motion-
            branding palette. It reads as a cat at taskbar scale without using
            cartoon outlines, whiskers, or a literal illustrated face.
        -->
        <Canvas x:Name="CatBody" RenderTransformOrigin="0.5,1">
            <Canvas.RenderTransform>
                <ScaleTransform x:Name="Breathe" ScaleX="1" ScaleY="1" CenterX="98" CenterY="84"/>
            </Canvas.RenderTransform>

            <!-- Tail: one confident burgundy gesture. -->
            <Path x:Name="Tail"
                  Data="M 78,67 C 59,78 46,68 52,53 C 55,46 62,45 64,50"
                  Fill="Transparent"
                  Stroke="#FFAD1F48"
                  StrokeThickness="7"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round">
                <Path.RenderTransform>
                    <RotateTransform x:Name="TailRot" Angle="0" CenterX="78" CenterY="67"/>
                </Path.RenderTransform>
            </Path>

            <!-- Low, architectural body with overlapping brand modules. -->
            <Rectangle Canvas.Left="69" Canvas.Top="43" Width="58" Height="42"
                       RadiusX="20" RadiusY="20" Fill="#FF08665F"/>
            <Ellipse Canvas.Left="63" Canvas.Top="44" Width="43" Height="40"
                     Fill="#FF1E5AF2"/>
            <Path Data="M 91,45 C 100,43 110,46 115,54 L 115,83 L 96,83 C 92,72 90,58 91,45 Z"
                  Fill="#FF24B2A5"/>
            <Path Data="M 72,68 C 79,64 87,64 94,69 L 91,84 L 72,84 Z"
                  Fill="#FFFF6846"/>

            <!-- Head and ears form one compact, forward-looking silhouette. -->
            <Path Data="M 96,43 L 98,21 L 108,28 L 119,19 L 123,42
                         C 128,49 126,60 119,65
                         C 111,70 99,67 95,59
                         C 92,53 92,48 96,43 Z"
                  Fill="#FF07534E"/>
            <Polygon Points="99,28 100,21 107,28" Fill="#FFFF6846"/>
            <Polygon Points="117,27 119,20 112,28" Fill="#FFFFC744"/>

            <!-- A single optical line and colour point imply a face. -->
            <Path Data="M 102,47 C 106,50 111,50 115,47"
                  Fill="Transparent"
                  Stroke="#FFFFC744"
                  StrokeThickness="2"
                  StrokeStartLineCap="Round"
                  StrokeEndLineCap="Round"/>
            <Ellipse Canvas.Left="118" Canvas.Top="51" Width="4" Height="4"
                     Fill="#FFFF6846"/>

            <!-- Grounded feet: simple capsules, no outlined paws. -->
            <Rectangle Canvas.Left="82" Canvas.Top="78" Width="18" Height="9"
                       RadiusX="4.5" RadiusY="4.5" Fill="#FF07534E"/>
            <Rectangle Canvas.Left="104" Canvas.Top="78" Width="22" Height="9"
                       RadiusX="4.5" RadiusY="4.5" Fill="#FFAD1F48"/>
        </Canvas>

        <!-- Ambient sleep/activity signal: abstract particles, not cartoon Zs. -->
        <Canvas x:Name="Zzz" Opacity="0">
            <Ellipse Canvas.Left="125" Canvas.Top="26" Width="5" Height="5"
                     Fill="#FF24B2A5"/>
            <Rectangle Canvas.Left="132" Canvas.Top="15" Width="7" Height="7"
                       RadiusX="2" RadiusY="2" Fill="#FFFFC744"
                       RenderTransformOrigin="0.5,0.5">
                <Rectangle.RenderTransform>
                    <RotateTransform Angle="45"/>
                </Rectangle.RenderTransform>
            </Rectangle>
            <Ellipse Canvas.Left="139" Canvas.Top="2" Width="8" Height="8"
                     Fill="#FFFF6846"/>
        </Canvas>
    </Canvas>
</Window>
