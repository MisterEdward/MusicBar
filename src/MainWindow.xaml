<Window x:Class="TaskbarMusic.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Taskbar Music"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ResizeMode="NoResize"
        SizeToContent="WidthAndHeight"
        ShowActivated="False"
        WindowStartupLocation="Manual"
        Left="-6000" Top="-6000"
        UseLayoutRounding="True"
        TextOptions.TextFormattingMode="Ideal"
        FontFamily="{StaticResource UiFont}">

    <!-- No margin/shadow/border: the pill is the window, sized to the taskbar and
         blended into it (translucent). Height + corner radius are set in code.
         RootGrid.Clip is set in code to cull anything spilling onto another monitor. -->
    <Grid x:Name="RootGrid">
        <Border x:Name="Pill"
                Height="44"
                Width="220"
                MinWidth="44"
                CornerRadius="22"
                Background="#01000000"
                BorderThickness="0"
                HorizontalAlignment="Left"
                VerticalAlignment="Center"
                RenderTransformOrigin="0.5,0.5">
            <Border.RenderTransform>
                <!-- Used for the subtle "settle" bounce on track change. -->
                <ScaleTransform x:Name="PillScale" ScaleX="1" ScaleY="1"/>
            </Border.RenderTransform>

            <Border.ContextMenu>
                <ContextMenu>
                    <MenuItem x:Name="MenuStartup" Header="Start with Windows" IsCheckable="True"
                              Click="OnToggleStartup"/>
                    <MenuItem x:Name="MenuLock" Header="Lock position" IsCheckable="True"
                              Click="OnToggleLock"/>
                    <MenuItem x:Name="MenuCat" Header="Idle cat" IsCheckable="True" IsChecked="True"
                              Click="OnToggleCat"/>
                    <MenuItem Header="Reset position" Click="OnResetPosition"/>
                    <Separator/>
                    <MenuItem Header="Exit" Click="OnExit"/>
                </ContextMenu>
            </Border.ContextMenu>

            <Grid x:Name="ContentClip" ClipToBounds="True">

                <!-- The audio-reactive dot-field background is inserted here in code,
                     as the first child so it sits behind everything else. -->

                <!-- ===== Expanded content ===== -->
                <Grid x:Name="ExpandedContent" Margin="6,0,8,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Album art: rounded via a Border background (an ImageBrush is
                         clipped to the CornerRadius; a raw Image would not be).
                         Size + CornerRadius are recomputed from the pill height. -->
                    <Border x:Name="ArtHost" Grid.Column="0" Width="32" Height="32" CornerRadius="9"
                            VerticalAlignment="Center">
                        <Border.Background>
                            <ImageBrush x:Name="ArtBrush" Stretch="UniformToFill"/>
                        </Border.Background>
                        <TextBlock x:Name="ArtFallback" Text="&#xE8D6;"
                                   FontFamily="{StaticResource IconFont}" FontSize="16"
                                   Foreground="{DynamicResource TextSecondary}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- Title • Artist, one line, vertically centred -->
                    <TextBlock Grid.Column="1" Margin="12,0,10,0"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               TextWrapping="NoWrap"
                               FontSize="13.5">
                        <Run x:Name="TitleRun" FontWeight="SemiBold" Foreground="{DynamicResource TextPrimary}"/><Run
                             x:Name="SepRun" Text="   •   " Foreground="{DynamicResource TextSecondary}"/><Run
                             x:Name="ArtistRun" Foreground="{DynamicResource TextSecondary}"/>
                    </TextBlock>

                    <!-- Transport buttons -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="PrevButton" Style="{StaticResource IconButton}"
                                Width="32" Height="40" FontSize="14" Content="&#xE892;"
                                Click="OnPrev" ToolTip="Previous"/>
                        <Button x:Name="PlayButton" Style="{StaticResource IconButton}"
                                Width="36" Height="40" FontSize="16" Content="&#xE768;"
                                Click="OnPlayPause" ToolTip="Play/Pause"/>
                        <Button x:Name="NextButton" Style="{StaticResource IconButton}"
                                Width="32" Height="40" FontSize="14" Content="&#xE893;"
                                Click="OnNext" ToolTip="Next"/>
                    </StackPanel>
                </Grid>

                <!-- (idle indicator is the code-inserted MorphIndicator) -->

                <!-- ===== Volume overlay (bottom hairline + %) ===== -->
                <Grid x:Name="VolumeOverlay" Opacity="0" VerticalAlignment="Bottom" Height="56">
                    <Border VerticalAlignment="Bottom" Height="3" Margin="10,0,10,5"
                            CornerRadius="2" Background="#30FFFFFF">
                        <Border x:Name="VolumeFill" HorizontalAlignment="Left" Width="0"
                                CornerRadius="2" Background="{DynamicResource AccentBrush}"/>
                    </Border>
                    <TextBlock x:Name="VolumeText" Text="" FontSize="11" FontWeight="SemiBold"
                               Foreground="{DynamicResource TextPrimary}"
                               HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,4,0,0"/>
                </Grid>

            </Grid>
        </Border>
    </Grid>
</Window>
