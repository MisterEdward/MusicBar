<Application x:Class="TaskbarMusic.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             ShutdownMode="OnExplicitShutdown">
    <Application.Resources>
        <ResourceDictionary>

            <!-- Segoe Fluent Icons on Win11, graceful fallback to MDL2 on Win10 -->
            <FontFamily x:Key="IconFont">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>
            <FontFamily x:Key="UiFont">Segoe UI Variable Text, Segoe UI</FontFamily>

            <!-- Dark "glass" palette (default). Light theme swaps these in code.
                 Translucent so the pill blends into the taskbar behind it. -->
            <SolidColorBrush x:Key="GlassBrush"    Color="#4D000000"/>
            <SolidColorBrush x:Key="StrokeBrush"   Color="#26FFFFFF"/>
            <SolidColorBrush x:Key="TextPrimary"   Color="#FFFFFFFF"/>
            <SolidColorBrush x:Key="TextSecondary" Color="#B4FFFFFF"/>
            <SolidColorBrush x:Key="IconHover"     Color="#20FFFFFF"/>
            <SolidColorBrush x:Key="IconPressed"   Color="#38FFFFFF"/>
            <SolidColorBrush x:Key="AccentBrush"   Color="#FF60CDFF"/>

            <!-- Fluent transport button: rounded, subtle hover/press states -->
            <Style x:Key="IconButton" TargetType="Button">
                <Setter Property="FontFamily" Value="{StaticResource IconFont}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Focusable" Value="False"/>
                <Setter Property="SnapsToDevicePixels" Value="True"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="bg" Background="{TemplateBinding Background}"
                                    CornerRadius="9" Padding="{TemplateBinding Padding}">
                                <ContentPresenter HorizontalAlignment="Center"
                                                  VerticalAlignment="Center"
                                                  TextElement.FontSize="{TemplateBinding FontSize}"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="{DynamicResource IconHover}"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter TargetName="bg" Property="Background" Value="{DynamicResource IconPressed}"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.35"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

        </ResourceDictionary>
    </Application.Resources>
</Application>
